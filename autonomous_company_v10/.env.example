# === Auth (une des trois options) ===
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=...
# Ou via: claude /login

# === Modeles ===
AUTONOMOUS_CEO_MODEL=claude-opus-4-7
AUTONOMOUS_WORKER_MODEL=claude-sonnet-4-6

# === Budget ===
AUTONOMOUS_DEFAULT_BUDGET_USD=5.00

# === Chemins ===
AUTONOMOUS_SQLITE_PATH=./data/company.db
AUTONOMOUS_PROMPTS_DIR=./prompts
AUTONOMOUS_TOOLS_ALLOWLIST_PATH=./config/tools_allowlist.yaml

# === Timeouts & limites ===
AUTONOMOUS_STEP_MAX_RETRIES=3
AUTONOMOUS_STEP_RETRY_BACKOFF_BASE=2.0
AUTONOMOUS_MESSAGE_TTL_SECONDS=3600
AUTONOMOUS_MAX_HOP_COUNT=5
AUTONOMOUS_DRAIN_REACTION_MAX_TURNS=20

# === Observabilite ===
AUTONOMOUS_LOG_LEVEL=INFO
AUTONOMOUS_LOG_FORMAT=console
AUTONOMOUS_OTEL_ENABLED=false
AUTONOMOUS_OTEL_EXPORTER=none
# AUTONOMOUS_OTEL_OTLP_ENDPOINT=http://localhost:4317

# === Web ===
AUTONOMOUS_CORS_ORIGINS=["http://localhost:3000"]
